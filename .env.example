CTR_GO_ADAPTER=telegram
CTR_GO_TELEGRAM_BOT_TOKEN=<telegram-bot-token>
CTR_GO_ALLOWED_USER_IDS=<telegram-user-id>
# For Feishu/Lark, prefer `ctr-go feishu setup` to create the app by QR scan.
# If you already have an enterprise self-built app, set these manually:
# CTR_GO_FEISHU_APP_ID=<feishu-app-id>
# CTR_GO_FEISHU_APP_SECRET=<feishu-app-secret>
# CTR_GO_FEISHU_ALLOWED_OPEN_IDS=<feishu-open-id>
# CTR_GO_FEISHU_ALLOWED_CHAT_IDS=<feishu-chat-id>
CTR_GO_DEFAULT_CWD=C:\Users\you\Projects\Codex
CTR_GO_PROJECTS_PROJECT_PREVIEW_LIMIT=7
CTR_GO_PROJECTS_CHAT_PREVIEW_LIMIT=3
CTR_GO_CHATS_PAGE_SIZE=8
CTR_GO_NOTIFY_SYSTEM=true
# When true, Feishu replies first try the local Codex Desktop IPC owner window,
# then fall back to the existing app-server path if Desktop is unavailable.
CTR_GO_OPEN_CODEX_DESKTOP_ON_FEISHU=false

# Optional screenshot demo.
CTR_DEMO_TELEGRAM_E2E=0
CTR_DEMO_TELEGRAM_CHAT_ID=<telegram-chat-id>
CTR_DEMO_KEEP_MESSAGES=false
